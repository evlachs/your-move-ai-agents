# Скопируй этот файл в .env и заполни своими значениями
# cp .env.example .env

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=owner/repository-name

# --- YandexGPT ---
# IAM-токен: yc iam create-token
# API-ключ:  в консоли Яндекс Клауд → Сервисные аккаунты
YANDEX_API_KEY=your_iam_token_or_api_key
YANDEX_FOLDER_ID=b1gxxxxxxxxxxxxxxxxx

# --- Email (Яндекс.Почта) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-bot@yandex.ru
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your-bot@yandex.ru
EMAIL_TO=recipient@example.com

# --- Хранилище ---
DB_PATH=data/agent_memory.db

# --- Расписание ---
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
TIMEZONE=Europe/Moscow
